# Copy to .env and fill in. .env is gitignored.

# --- Splunk Enterprise (local dev instance) ---
SPLUNK_HOST=localhost
SPLUNK_MGMT_PORT=8089
SPLUNK_WEB_PORT=8000
SPLUNK_TOKEN=paste_your_bearer_token_here
SPLUNK_VERIFY_SSL=false

# --- Ollama (local model server) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=hf.co/gabriellarson/Foundation-Sec-8B-Instruct-GGUF:Q4_K_M
OLLAMA_FALLBACK_MODEL=llama3.1:8b

# --- Splunk MCP Server (set after configuring app) ---
SPLUNK_MCP_URL=http://localhost:8000/en-US/app/splunk_mcp_server/
SPLUNK_MCP_TOKEN=

# --- AgentGate audit ---
AGENTGATE_AUDIT_INDEX=agentgate_audit
AGENTGATE_HEC_URL=https://localhost:8088/services/collector/event
AGENTGATE_HEC_TOKEN=
